# =========================
# Hotleno Environment Example
# Copy to .env.local for local development.
# Do not commit real secrets.
# =========================

# Public app URL used for links, redirects, and referral URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/hotleno

# Strong server-side JWT secret. Never use a weak/default value.
JWT_SECRET=replace-with-a-long-random-secret


# =========================
# Development Controls
# =========================

# Local development only. Must be false in production.
NEXT_PUBLIC_DEV_ADMIN_BYPASS=false
NEXT_PUBLIC_DEV_PREVIEW_ALL_PAGES=false

# Enables mock supplier booking after payment in local development only.
MOCK_SUPPLIER_BOOKING_ENABLED=false


# =========================
# Supplier Layer
# =========================

# Single active supplier for development: mock, hotelbeds, tbo, travellanda.
SUPPLIER_PROVIDER=mock

# Optional comma-separated supplier list for unified search.
SUPPLIER_PROVIDERS=

# Timeout for supplier search fallback in milliseconds.
SUPPLIER_SEARCH_TIMEOUT_MS=8000

# B2B supplier provider. Use mock until real suppliers are connected.
B2B_SUPPLIER_PROVIDER=mock

# Optional internal API keys placeholder for future service-to-service integrations.
API_KEYS=


# =========================
# Hotelbeds
# =========================

# Future Hotelbeds API key. Leave empty until real integration is enabled.
HOTELBEDS_API_KEY=

# Future Hotelbeds secret. Leave empty until real integration is enabled.
HOTELBEDS_SECRET=
HOTELBEDS_API_SECRET=

# Hotelbeds base URL placeholders. Keep empty in examples.
HOTELBEDS_BASE_URL=
HOTELBEDS_SECURE_BASE_URL=
HOTELBEDS_CONTENT_BASE_URL=
HOTELBEDS_BOOKING_BASE_URL=

# Hotelbeds autocomplete source: api, database, or auto.
HOTELBEDS_CONTENT_SEARCH_SOURCE=api

# Hotelbeds Accommodation certification/search controls.
HOTELBEDS_HOTELS_SEARCH_ENABLED=false
HOTELBEDS_HOTELS_BOOKING_ENABLED=false
HOTELBEDS_HOTELS_CERTIFICATION_AUTO_RUN=false


# =========================
# Hotelbeds Transfers
# =========================

# Separate Transfers credentials. Do not reuse Hotel API credentials here.
HOTELBEDS_TRANSFERS_API_KEY=
HOTELBEDS_TRANSFERS_SECRET=
HOTELBEDS_TRANSFERS_BASE_URL=https://api.test.hotelbeds.com/transfer-api/1.0
HOTELBEDS_TRANSFERS_CACHE_BASE_URL=https://api.test.hotelbeds.com/transfer-cache-api/1.0
HOTELBEDS_TRANSFERS_SEARCH_ENABLED=false
HOTELBEDS_TRANSFERS_BOOKING_ENABLED=false
HOTELBEDS_TRANSFERS_CERTIFICATION_CONFIRM=false


# =========================
# Hotelbeds Activities
# =========================

HOTELBEDS_ACTIVITIES_API_KEY=
HOTELBEDS_ACTIVITIES_SECRET=
HOTELBEDS_ACTIVITIES_BASE_URL=https://api.test.hotelbeds.com/activity-api/3.0
HOTELBEDS_ACTIVITIES_CONTENT_BASE_URL=https://api.test.hotelbeds.com/activity-content-api/3.0
HOTELBEDS_ACTIVITIES_SEARCH_ENABLED=false
HOTELBEDS_ACTIVITIES_BOOKING_ENABLED=false


# =========================
# TBO
# =========================

# TBO base URL for staging/production.
TBO_BASE_URL=

# TBO username.
TBO_USERNAME=

# TBO password.
TBO_PASSWORD=

# TBO environment label, e.g. staging or production.
TBO_ENV=staging


# =========================
# Travellanda
# =========================

# Travellanda API URL used by current proxy/client code.
NEXT_PUBLIC_TRAVELLANDA_API_URL=

# Travellanda username used by current XML/API integration.
TRAVELLANDA_USERNAME=

# Travellanda password used by current XML/API integration.
TRAVELLANDA_PASSWORD=

# Optional future Travellanda API key if provider contract changes.
TRAVELLANDA_API_KEY=


# =========================
# Stripe Test Mode
# =========================

# Stripe publishable test key for client-side checkout setup.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe secret test key. Must start with sk_test_ while STRIPE_MODE=test.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for local/test webhooks.
STRIPE_WEBHOOK_SECRET=

# Stripe mode. Keep test unless live mode is intentionally enabled later.
STRIPE_MODE=test

# Legacy/compat Stripe environment flag used by some routes.
STRIPE_ENV=test

# Server-side flag to enable Stripe Checkout creation.
STRIPE_CHECKOUT_ENABLED=false

# Client-side flag to show/enable Stripe checkout actions.
NEXT_PUBLIC_ENABLE_STRIPE_CHECKOUT=false
